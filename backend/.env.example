# PostgreSQL connection string (Neon free tier works).
# Format: postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME

# Backend public URL (used for CORS)
API_BASE_URL=http://localhost:8000

# Frontend URL allowed to call the API (must match exactly for CORS)
FRONTEND_URL=http://localhost:3000

# Scheduler polling interval in seconds
SCHEDULER_POLL_SECONDS=60

# --- Auth / crypto secrets ---
# Required in production. Auto-generated locally so the dev server still boots.
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
SESSION_SECRET=

# Must be a valid Fernet key. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Loss of this key invalidates all stored platform tokens.
ENCRYPTION_KEY=

# --- Per-platform credentials ---
# ContentSync is multi-tenant: each user stores their own keys at /settings.
# The env vars below are intentionally NOT used at runtime anymore — leave
# them blank. They are kept here only as a reminder of which platforms are
# supported.
# DEVTO_API_KEY=
# WORDPRESS_ACCESS_TOKEN=
# WORDPRESS_SITE_ID=
# NOTION_API_KEY=
# NOTION_PARENT_PAGE_ID=
# BLOGGER_ACCESS_TOKEN=
# BLOGGER_BLOG_ID=
